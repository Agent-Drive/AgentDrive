# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentdrive

# GCS
GCS_BUCKET=agentdrive-files
# GOOGLE_APPLICATION_CREDENTIALS is NOT needed for local dev.
# Run: gcloud auth application-default login
# Only set this for production/CI with a service account JSON file.

# Auth
API_KEY_HASH_ROUNDS=12

# Voyage AI
VOYAGE_API_KEY=your-key-here

# Cohere
COHERE_API_KEY=your-key-here

# Environment
ENVIRONMENT=development
