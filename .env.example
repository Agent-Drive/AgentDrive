# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentdrive

# GCS — run: gcloud auth application-default login

# Voyage AI
VOYAGE_API_KEY=your-key-here

# Cohere
COHERE_API_KEY=your-key-here

# Enrichment (Gemini 2.5 Flash via Google AI Studio)
ENRICHMENT_API_KEY=your-key-here

# WorkOS Auth
WORKOS_API_KEY=your-key-here
WORKOS_CLIENT_ID=your-client-id-here

# Environment
ENVIRONMENT=development
